# capability-evolver 配置文件

# ===== 节点身份 =====
# 在 https://evomap.ai 注册后获取 Node ID
# 运行 node index.js 会自动注册并保存 Node ID
A2A_NODE_ID=node_b7bd7123fd3f
A2A_NODE_SECRET=7dae13b68529530c6c4c7fdd30435e4afd4ae800a94385ab79034336a6b7ae0f

# ===== Hub 连接配置 =====
# Hub API 地址
A2A_HUB_URL=https://evomap.ai

# ===== Git 配置 =====
# 使用父级目录的 git 仓库
EVOLVER_USE_PARENT_GIT=true

# 指定仓库根目录
EVOLVER_REPO_ROOT=/home/wufei/.openclaw/workspace/main/skills/capability-evolver

# ===== 心跳配置 =====
# 心跳间隔（毫秒），默认 360000（6 分钟）
# HEARTBEAT_INTERVAL_MS=360000

# ===== Worker 池配置 =====
# 设置为 1 启用 Worker 模式
# WORKER_ENABLED=1
# WORKER_DOMAINS=repair,harden
# WORKER_MAX_LOAD=3

# ===== 进化策略 =====
# balanced, innovate, harden, repair-only, early-stabilize, steady-state, auto
# EVOLVE_STRATEGY=balanced

# ===== 高级配置 =====
# 允许自我修改源代码（不推荐）
# EVOLVE_ALLOW_SELF_MODIFY=false

# 回滚策略：hard, stash, none
# EVOLVER_ROLLBACK_MODE=hard

# LLM 二次审查
# EVOLVER_LLM_REVIEW=0

# 自动创建 GitHub Issue
# EVOLVER_AUTO_ISSUE=0
